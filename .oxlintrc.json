{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "options": {
    "typeAware": true,
    "typeCheck": true
  },
  "plugins": ["typescript", "import", "unicorn", "promise", "node"],
  "categories": {
    "correctness": "warn",
    "suspicious": "warn"
  },
  "env": {
    "builtin": true,
    "browser": true,
    "node": true
  },
  "rules": {
    "typescript/ban-ts-comment": "warn",
    "typescript/no-explicit-any": [
      "warn",
      {
        "fixToUnknown": true,
        "ignoreRestArgs": true
      }
    ],
    "typescript/no-non-null-asserted-optional-chain": "warn",
    "typescript/no-unsafe-function-type": "warn",
    "typescript/no-wrapper-object-types": "warn",
    "typescript/no-require-imports": "warn",
    "typescript/no-floating-promises": "warn",
    "typescript/no-misused-promises": "warn",
    "typescript/await-thenable": "warn",
    "promise/catch-or-return": "warn",
    "import/no-cycle": "warn",
    "typescript/no-empty-object-type": "warn",
    "typescript/no-duplicate-enum-values": "warn",
    "typescript/no-misused-new": "warn",
    "typescript/no-this-alias": "warn",
    "typescript/no-unnecessary-type-constraint": "warn",
    "typescript/no-unsafe-declaration-merging": "warn",
    "no-unused-vars": "warn",
    "typescript/no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_"
      }
    ]
  },
  "overrides": [
    {
      "files": ["**/*.ts", "**/*.tsx", "**/*.mts", "**/*.cts"],
      "rules": {
        // Disabling native JS rules that the TS Compiler already handles
        "constructor-super": "off",
        "getter-return": "off",
        "no-class-assign": "off",
        "no-const-assign": "off",
        "no-dupe-class-members": "off",
        "no-dupe-keys": "off",
        "no-func-assign": "off",
        "no-import-assign": "off",
        "no-new-native-nonconstructor": "off",
        "no-obj-calls": "off",
        "no-redeclare": "off",
        "no-setter-return": "off",
        "no-this-before-super": "off",
        "no-unreachable": "off",
        "no-unsafe-negation": "off",
        "no-with": "off",

        // Forcing modern syntax in TS files
        "no-var": "warn",
        "prefer-const": "warn",
        "prefer-rest-params": "warn",
        "prefer-spread": "warn"
      }
    }
  ]
}
