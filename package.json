{
  "name": "@iamvikshan/git-sync",
  "version": "1.1.0",
  "description": "Synchronize GitHub repository with GitLab including branches, PRs, and issues",
  "keywords": [
    "actions",
    "automation",
    "git",
    "github",
    "gitlab"
  ],
  "homepage": "https://github.com/iamvikshan/gitsync#readme",
  "bugs": {
    "url": "https://github.com/iamvikshan/gitsync/issues"
  },
  "license": "MIT",
  "author": "vikshan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamvikshan/gitsync.git"
  },
  "main": "dist/index.js",
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "start": "bun src/index.ts",
    "lint:fix": "oxlint --fix .",
    "lint": "oxlint .",
    "f": "oxfmt --write .",
    "f:check": "oxfmt --check .",
    "type": "tsgo --noEmit",
    "check": "bun run type && bun run lint",
    "prepare": "test -d .git && husky || true",
    "bs": "mkdir -p scripts && curl -sL https://raw.githubusercontent.com/iamvikshan/.github/main/scripts/bootstrap.sh > scripts/bootstrap.sh && chmod +x scripts/bootstrap.sh && scripts/bootstrap.sh",
    "upd": "sudo apt update && sudo apt upgrade -y && bun upgrade && bun update --latest && bun i && bun f"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@gitbeaker/rest": "^43.8.0",
    "@octokit/rest": "^22.0.1",
    "deepmerge": "^4.3.1",
    "js-yaml": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/bun": "^1.3.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.1",
    "axios": "^1.18.1",
    "conventional-changelog-conventionalcommits": "^10.2.1",
    "conventional-changelog-gitmoji": "^0.2.5",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.25.0",
    "semantic-release": "^25.0.7",
    "semantic-release-gitmoji": "^1.6.9",
    "typescript": "^7.0.0-dev.20260707.2"
  }
}
