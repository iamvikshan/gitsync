{
  "name": "@iamvikshan/git-sync",
  "description": "Synchronize GitHub repository with GitLab including branches, PRs, and issues",
  "version": "1.1.0",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "main": "dist/index.js",
  "scripts": {
    "lint": "eslint src/**/*.ts",
    "start": "bun src/index.ts",
    "build": "ncc build src/index.ts -o dist",
    "f": "(git diff --name-only --diff-filter=ACMR HEAD && git ls-files --others --exclude-standard) | xargs bunx prettier --write --ignore-unknown",
    "f:all": "prettier --write .",
    "f:check": "prettier --check .",
    "lint:fix": "eslint . --fix",
    "check": "eslint . && tsc --noEmit",
    "prepare": "test -d .git && husky || true"
  },
  "keywords": [
    "github",
    "actions",
    "gitlab",
    "automation",
    "git"
  ],
  "author": "vikshan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamvikshan/gitsync.git"
  },
  "bugs": {
    "url": "https://github.com/iamvikshan/gitsync/issues"
  },
  "homepage": "https://github.com/iamvikshan/gitsync#readme",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@gitbeaker/rest": "^43.8.0",
    "@octokit/rest": "^22.0.1",
    "deepmerge": "^4.3.1",
    "js-yaml": "^4.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.2",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vercel/ncc": "^0.44.0",
    "axios": "^1.16.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "conventional-changelog-gitmoji": "^0.2.5",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "semantic-release-gitmoji": "^1.6.9",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  }
}
