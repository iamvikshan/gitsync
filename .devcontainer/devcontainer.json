{
  "name": "Ubuntu + Bun",
  "image": "vikshan/ubuntu-bun:latest",
  "customizations": {
    "vscode": {
      "extensions": [
        "oven.bun-vscode",
        "WakaTime.vscode-wakatime",
        "coderabbit.coderabbit-vscode",
        "aaron-bond.better-comments",
        "usernamehw.errorlens",
        "TypeScriptTeam.native-preview",
        "eamodio.gitlens",
        "oxc.oxc-vscode"
      ]
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    }
  },
  "remoteUser": "root",
  "postCreateCommand": "bun i && bun bs"
}
